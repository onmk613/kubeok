[Unit]
Description=etcd
Documentation=https://github.com/etcd-io/etcd
After=network.target

[Service]
Type=notify
ExecStart={{ bin_dir }}/etcd \
  --name {{ inventory_hostname }} \
  --initial-cluster-token etcd-cluster-0 \
  --data-dir={{ etcd_data_dir }} \
  --client-cert-auth \
  --trusted-ca-file={{ etcd_cert_dir }}/etcd-ca.pem \
  --cert-file={{ etcd_cert_dir }}/etcd.pem \
  --key-file={{ etcd_cert_dir }}/etcd-key.pem \
  --listen-client-urls https://{{ etcd_host }}:{{ etcd_client_port }},https://127.0.0.1:{{ etcd_client_port }} \
  --advertise-client-urls https://{{ etcd_host }}:{{ etcd_client_port }} \
  --peer-client-cert-auth \
  --peer-trusted-ca-file={{ etcd_cert_dir }}/etcd-ca.pem \
  --peer-cert-file={{ etcd_cert_dir }}/etcd.pem \
  --peer-key-file={{ etcd_cert_dir }}/etcd-key.pem \
  --listen-peer-urls https://{{ etcd_host }}:{{ etcd_peer_port }} \
  --initial-advertise-peer-urls https://{{ etcd_host }}:{{ etcd_peer_port }} \
  --initial-cluster {{ etcd_initial_cluster }} \
  --listen-metrics-urls https://{{ etcd_host }}:{{ etcd_metrics_port }},https://127.0.0.1:{{ etcd_metrics_port }} \
  --quota-backend-bytes=8589934592 \
  --auto-compaction-retention=1 \
  --snapshot-count=50000 \
  --wal-dir {{ etcd_wal_dir }} \
  --auto-compaction-mode=periodic \
  --max-request-bytes=10485760 \
  --initial-cluster-state=new
NotifyAccess=all
Restart=always
RestartSec=10s
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target