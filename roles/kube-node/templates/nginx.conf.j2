error_log stderr notice;

worker_processes 1;
events {
  multi_accept on;
  use epoll;
  worker_connections 1024;
}

stream {
    upstream kube_apiserver {
        least_conn;
        {% for host in groups['kube_control_plane'] %}
        {% set ip = hostvars[host]['internal_ip'] | default(hostvars[host]['ansible_host']) %}
        {% set port = hostvars[host]['kube_apiserver_port'] | default(kube_apiserver_port) %}
        server {{ ip }}:{{ port }} max_fails=3 fail_timeout=30s;
        {% endfor %}
    }
    server {
        listen        127.0.0.1:{{ kube_apiserver_port }};
        proxy_pass    kube_apiserver;
        proxy_timeout 10m;
        proxy_connect_timeout 1s;
    }
}
