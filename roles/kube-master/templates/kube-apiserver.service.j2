[Unit]
Description=Kubernetes API Server
Documentation=https://github.com/kubernetes/kubernetes
After=network.target

[Service]
ExecStart={{ bin_dir }}/kube-apiserver \
{% if enable_apiserver_audit -%}
  --audit-log-maxage=30 \
  --audit-log-maxbackup=4 \
  --audit-log-maxsize=100 \
  --audit-policy-file={{ audit_policy_file }} \
  --audit-log-path={{ audit_log_path }} \
{% endif -%}
  --allow-privileged=true \
  --runtime-config=api/all=true \
  --advertise-address={{ kube_master_ip }} \
  --bind-address={{ kube_master_ip }} \
  --secure-port={{ kube_apiserver_port }} \
  --authorization-mode=Node,RBAC \
  --client-ca-file={{ kube_cert_dir }}/k8s-ca.pem \
  --enable-admission-plugins=NodeRestriction \
  --endpoint-reconciler-type=lease \
  --tls-cert-file={{ kube_cert_dir }}/kubernetes.pem \
  --tls-private-key-file={{ kube_cert_dir }}/kubernetes-key.pem \
  --etcd-cafile={{ kube_cert_dir }}/etcd-ca.pem \
  --etcd-certfile={{ kube_cert_dir }}/etcd-client.pem \
  --etcd-keyfile={{ kube_cert_dir }}/etcd-client-key.pem \
  --etcd-servers={{ etcd_servers }} \
  --kubelet-certificate-authority={{ kube_cert_dir }}/k8s-ca.pem \
  --kubelet-client-certificate={{ kube_cert_dir }}/kubernetes.pem \
  --kubelet-client-key={{ kube_cert_dir }}/kubernetes-key.pem \
  --kubelet-preferred-address-types=InternalIP,Hostname,ExternalIP \
{% if enable_bootstrap_token_auth %}
  --enable-bootstrap-token-auth=true \
{% endif %}
  --service-account-key-file={{ kube_cert_dir }}/sa.pem \
  --service-account-signing-key-file={{ kube_cert_dir }}/sa-key.pem \
  --service-account-issuer=https://kubernetes.default.svc.cluster.local \
  --service-cluster-ip-range={{ services_cidr }} \
  --service-node-port-range={{ kube_nodeport_range }} \
  --requestheader-client-ca-file={{ kube_cert_dir }}/k8s-ca.pem \
  --proxy-client-cert-file={{ kube_cert_dir }}/front-proxy-client.pem \
  --proxy-client-key-file={{ kube_cert_dir }}/front-proxy-client-key.pem \
  --requestheader-allowed-names=front-proxy-client \
  --requestheader-extra-headers-prefix=X-Remote-Extra- \
  --requestheader-group-headers=X-Remote-Group \
  --requestheader-username-headers=X-Remote-User \
  --enable-aggregator-routing=true \
  --v=2
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
